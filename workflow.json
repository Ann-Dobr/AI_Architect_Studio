        "jsonBody": "={\n  \"model\": \"gpt-4o\",\n  \"messages\": [{\n    \"role\": \"user\",\n    \"content\": [\n      {\n        \"type\": \"text\",\n        \"text\": \"Извлеки из изображения описание процесса для построения диаграммы. Верни только текст описания, без лишних слов.\"\n      },\n      {\n        \"type\": \"image_url\",\n        \"image_url\": {\n          \"url\": \"data:{{ $json.body.fileMime }};base64,{{ $json.body.fileBase64 }}\"\n        }\n      }\n    ]\n  }]\n}",
